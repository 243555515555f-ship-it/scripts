-- ========== HEALTH BAR ESP ==========
local HealthBarESP = {
    Enabled = false,
    Bars = {}
}

local healthConnection = nil

local function createHealthBar(player)
    if not HealthBarESP.Enabled then return end
    if player == Players.LocalPlayer then return end
    
    local bar = Drawing.new("Square")
    bar.Thickness = 1
    bar.Filled = true
    bar.Color = Color3.fromRGB(0, 255, 0)
    bar.Transparency = 0.5
    bar.Visible = false
    HealthBarESP.Bars[player] = bar
end

local function updateHealthBarESP()
    if not HealthBarESP.Enabled then return end
    
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= Players.LocalPlayer and player.Character then
            local head = player.Character:FindFirstChild("Head")
            local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
            
            if head and humanoid and humanoid.Health > 0 then
                local headPos, onScreen = Camera:WorldToViewportPoint(head.Position)
                
                if onScreen then
                    local healthPercent = humanoid.Health / humanoid.MaxHealth
                    local barWidth = 50
                    local barHeight = 6
                    
                    if not HealthBarESP.Bars[player] then
                        createHealthBar(player)
                    end
                    
                    local bar = HealthBarESP.Bars[player]
                    if bar then
                        bar.Position = Vector2.new(headPos.X - barWidth/2, headPos.Y + 20)
                        bar.Size = Vector2.new(barWidth * healthPercent, barHeight)
                        bar.Visible = true
                        
                        if healthPercent > 0.6 then
                            bar.Color = Color3.fromRGB(0, 255, 0)
                        elseif healthPercent > 0.3 then
                            bar.Color = Color3.fromRGB(255, 255, 0)
                        else
                            bar.Color = Color3.fromRGB(255, 0, 0)
                        end
                    end
                elseif HealthBarESP.Bars[player] then
                    HealthBarESP.Bars[player].Visible = false
                end
            elseif HealthBarESP.Bars[player] then
                HealthBarESP.Bars[player].Visible = false
            end
        end
    end
end

ESPTab:Toggle("Health Bar ESP", false, function(state)
    HealthBarESP.Enabled = state
    
    if state then
        for _, player in ipairs(Players:GetPlayers()) do
            createHealthBar(player)
        end
        if not healthConnection then
            healthConnection = RunService.RenderStepped:Connect(updateHealthBarESP)
        end
    else
        if healthConnection then
            healthConnection:Disconnect()
            healthConnection = nil
        end
        for _, bar in pairs(HealthBarESP.Bars) do
            if bar then bar:Remove() end
        end
        HealthBarESP.Bars = {}
    end
end)

