-- Rainbow Highlight ESP (Cached + throttled)
local RainbowHighlightESP = {Enabled = false, GlobalHighlight = nil, Tracked = {}, RainbowConn = nil}

local function toggleRainbowHighlightESP(state)
    RainbowHighlightESP.Enabled = state
    if state then
        if not RainbowHighlightESP.GlobalHighlight then
            local hl = Instance.new("Highlight")
            hl.Name = "GlobalRainbowESP"
            hl.FillTransparency = 1
            hl.OutlineTransparency = 0
            hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
            RainbowHighlightESP.GlobalHighlight = hl
        end

        RainbowHighlightESP.RainbowConn = RunService.RenderStepped:Connect(function()
            if not RainbowHighlightESP.Enabled then return end
            local hue = (tick() * 0.2) % 1
            local col = Color3.fromHSV(hue, 1, 1)
            if RainbowHighlightESP.GlobalHighlight then
                RainbowHighlightESP.GlobalHighlight.OutlineColor = col
            end
        end)

        -- Player management (lightweight)
        for _, plr in Players:GetPlayers() do
            if plr ~= player and plr.Character then
                local clone = RainbowHighlightESP.GlobalHighlight:Clone()
                clone.Parent = plr.Character
                RainbowHighlightESP.Tracked[plr] = clone
            end
        end
    else
        if RainbowHighlightESP.RainbowConn then RainbowHighlightESP.RainbowConn:Disconnect() end
        for _, hl in pairs(RainbowHighlightESP.Tracked) do
            pcall(function() hl:Destroy() end)
        end
        RainbowHighlightESP.Tracked = {}
        if RainbowHighlightESP.GlobalHighlight then
            pcall(function() RainbowHighlightESP.GlobalHighlight:Destroy() end)
        end
    end
end

