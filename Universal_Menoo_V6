if MenooWindow.CreateFloatingButton then
    MenooWindow:CreateFloatingButton()
end

UserInputService.InputBegan:Connect(function(input, processed)
    if processed then return end
    if input.KeyCode == Enum.KeyCode.F5 then
        if MenooWindow.ToggleVisibility then
            MenooWindow:ToggleVisibility()
        end
    end
end)

-- Emergency stop (END key)
UserInputService.InputBegan:Connect(function(input, processed)
    if processed then return end
    if input.KeyCode == Enum.KeyCode.End then
        -- Disable all toggles
        toggleRainbowHighlightESP(false)
        toggleRainbowNameESP(false)
        toggleXray(false)
        toggleHitbox(false)
        if walkflinging then walkflinging = false end
        Notify("EMERGENCY STOP - All features disabled", 3)
    end
end)

Notify("Menoo V6 Loaded Successfully! Press F5 to toggle menu", 5)
