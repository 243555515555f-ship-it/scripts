local PlayerValue = {
    savedValues = {
        fieldOfView = nil,
        cameraType = nil,
        cframe = nil,
        focus = nil,
        mouseIconEnabled = nil,
        mouseBehavior = nil
    },
    isSaved = false
}

function PlayerValue.Push()
    if PlayerValue.isSaved then
        warn("PlayerValue: Already saved! Call Pop() first")
        return
    end
    
    PlayerValue.savedValues.fieldOfView = Camera.FieldOfView
    PlayerValue.savedValues.cameraType = Camera.CameraType
    PlayerValue.savedValues.cframe = Camera.CFrame
    PlayerValue.savedValues.focus = Camera.Focus
    PlayerValue.savedValues.mouseIconEnabled = UserInputService.MouseIconEnabled
    PlayerValue.savedValues.mouseBehavior = UserInputService.MouseBehavior
    
    Camera.FieldOfView = 70
    Camera.CameraType = Enum.CameraType.Custom
    UserInputService.MouseIconEnabled = true
    UserInputService.MouseBehavior = Enum.MouseBehavior.Default
    
    PlayerValue.isSaved = true
end

function PlayerValue.Pop()
    if not PlayerValue.isSaved then
        warn("PlayerValue: Nothing to restore! Call Push() first")
        return
    end
    
    if PlayerValue.savedValues.fieldOfView then
        Camera.FieldOfView = PlayerValue.savedValues.fieldOfView
    end
    if PlayerValue.savedValues.cameraType then
        Camera.CameraType = PlayerValue.savedValues.cameraType
    end
    if PlayerValue.savedValues.cframe then
        Camera.CFrame = PlayerValue.savedValues.cframe
    end
    if PlayerValue.savedValues.focus then
        Camera.Focus = PlayerValue.savedValues.focus
    end
    if PlayerValue.savedValues.mouseIconEnabled ~= nil then
        UserInputService.MouseIconEnabled = PlayerValue.savedValues.mouseIconEnabled
    end
    if PlayerValue.savedValues.mouseBehavior then
        UserInputService.MouseBehavior = PlayerValue.savedValues.mouseBehavior
    end
    
    for key in pairs(PlayerValue.savedValues) do
        PlayerValue.savedValues[key] = nil
    end
    PlayerValue.isSaved = false
end

function PlayerValue.Reset()
    if PlayerValue.isSaved then
        PlayerValue.Pop()
    end
    PlayerValue.isSaved = false
    for key in pairs(PlayerValue.savedValues) do
        PlayerValue.savedValues[key] = nil
    end
end

