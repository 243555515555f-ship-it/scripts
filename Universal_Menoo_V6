local Flight = {
    Enabled = false,
    Speed = 50,
    VerticalUp = false,
    VerticalDown = false,
    Connection = nil,
    ForceName = "FlightForce_" .. math.random(100, 999)
}

local CAS = game:GetService("ContextActionService")
local ACTION_NAME = "DisableCtrlGameBind012908746"

local KeyState = {W = 0, S = 0, A = 0, D = 0}

local function DisableGameControl()
    CAS:BindActionAtPriority(ACTION_NAME, function(_, inputState)
        if inputState == Enum.UserInputState.Begin then
            Flight.VerticalDown = true
        elseif inputState == Enum.UserInputState.End then
            Flight.VerticalDown = false
        end
        return Enum.ContextActionResult.Sink
    end, false, Enum.ContextActionPriority.High.Value + 1000, Enum.KeyCode.LeftControl, Enum.KeyCode.RightControl)
end

local function EnableGameControl()
    Flight.VerticalDown = false
    pcall(function() CAS:UnbindAction(ACTION_NAME) end)
end

UserInputService.InputBegan:Connect(function(input, processed)
    if processed then return end
    local kc = input.KeyCode
    if KeyState[kc.Name] then KeyState[kc.Name] = 1 end
    if kc == Enum.KeyCode.Space then Flight.VerticalUp = true end
end)

UserInputService.InputEnded:Connect(function(input)
    local kc = input.KeyCode
    if KeyState[kc.Name] then KeyState[kc.Name] = 0 end
    if kc == Enum.KeyCode.Space then Flight.VerticalUp = false end
end)

local function flightUpdate()
    if not Flight.Enabled then return end
    local rp = getRootPart()
    if not rp then return end

    local cam = Workspace.CurrentCamera
    local cf = cam.CFrame
    local vertical = (Flight.VerticalUp and 1 or 0) - (Flight.VerticalDown and 1 or 0)
    local forward = KeyState.W - KeyState.S
    local side = KeyState.D - KeyState.A

    local moveDir = (cf.LookVector * Vector3.new(forward, 0, forward) + cf.RightVector * Vector3.new(side, 0, side)).Unit
    if moveDir.Magnitude == 0 then moveDir = Vector3.new(0,0,0) end

    local force = rp:FindFirstChild(Flight.ForceName)
    if force then
        force.Velocity = moveDir * Flight.Speed + Vector3.new(0, vertical * Flight.Speed, 0)
    end
end

local function startFlight()
    if Flight.Enabled then return end
    Flight.Enabled = true
    local rp = getRootPart()
    if not rp then return end

    local bv = Instance.new("BodyVelocity")
    bv.Name = Flight.ForceName
    bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
    bv.Velocity = Vector3.zero
    bv.Parent = rp

    Flight.Connection = RunService.Heartbeat:Connect(flightUpdate)
    local hum = getPlayerHumanoid()
    if hum then hum.PlatformStand = true end
end

local function stopFlight()
    Flight.Enabled = false
    if Flight.Connection then
        Flight.Connection:Disconnect()
        Flight.Connection = nil
    end
    local rp = getRootPart()
    local bv = rp and rp:FindFirstChild(Flight.ForceName)
    if bv then bv:Destroy() end
    local hum = getPlayerHumanoid()
    if hum then hum.PlatformStand = false end
end

PlrBypassTab:Slider("Fly Speed", 10, 500, 50, function(value) Flight.Speed = value end)
PlrBypassTab:Toggle("Fly On/Off", false, function(state)
    if state then
        DisableGameControl()
        startFlight()
    else
        EnableGameControl()
        stopFlight()
    end
end)

